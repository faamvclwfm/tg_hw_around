{
  "version": 2,
  "functions": {
    "api/webhook.js": {
      "memory": 256,
      "maxDuration": 15
    }
  },
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.js"
    }
  ],
  "crons": [
    {
      "path": "/api/remindersCron",
      "schedule": "0 19 * * *"
    }
  ]
}